# Credit ledger backend: "memory" (default) or "redis"
ONE_API_STORE=memory

# Starting balance seeded for every account on first touch
ONE_API_DEFAULT_BALANCE=100

# Only used when ONE_API_STORE=redis
ONE_API_REDIS_URL=redis://localhost:6379/0

# OpenAI key used by the agent loop (no prefix — read directly from env)
OPENAI_API_KEY=sk-...
